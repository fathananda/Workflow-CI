name: iris_classification_fathi

conda_env: conda.yaml

entry_points:
  main:
    parameters:
      dataset_path:
        type: string
        default: "iris_preprocessing.csv"
      n_estimators:
        type: int
        default: 100
      max_depth:
        type: int
        default: 5
      min_samples_split:
        type: int
        default: 2
      test_size:
        type: float
        default: 0.2
      random_state:
        type: int
        default: 42
    command: "python modelling.py --dataset_path {dataset_path} --n_estimators {n_estimators} --max_depth {max_depth} --min_samples_split {min_samples_split} --test_size {test_size} --random_state {random_state}"
